 * Categorize an error using expanded categories with sub-categories and fuzzy matching.
 * Priority: sub-category keywords (exact) > category fuzzy keywords > unknown
 */
function categorizeError(error) {
  const text = ((error.problem || '') + ' ' + (error.message || '') + ' ' + (error.stack || '')).toLowerCase();

  // Phase 1: Check each category's sub-categories (exact keyword match first)
  for (const [category, config] of Object.entries(AI_ASSISTED_CATEGORIES)) {
    for (const [subCat, subConfig] of Object.entries(config.subCategories || {})) {
      for (const keyword of subConfig.keywords) {
        if (text.includes(keyword.toLowerCase())) {
          return {
            category,
            subCategory: subCat,
            suggestion: subConfig.suggestion
          };
        }
      }
    }
  }

  // Phase 2: Fuzzy matching on category-level keywords
  for (const [category, config] of Object.entries(AI_ASSISTED_CATEGORIES)) {
    const fuzzy = config.fuzzy || [];
    for (const kw of fuzzy) {
      // Simple fuzzy: check if keyword appears as substring
      if (text.includes(kw.toLowerCase())) {
        return {
          category,
          subCategory: 'general',
          suggestion: config.suggestion
        };
      }
    }
  }

  return { category: 'unknown', subCategory: null, suggestion: '需要人工分析' };
}

