      log(`⏭️ Prevention Rule already in AGENTS.md: ${rule.title}`);
      rule.applied = true;
      appliedRules.push(rule);
      continue;
    }

    // Build Prevention Rule block
    const ruleBlock = `\n${rule.rule}\n`;

    // Find insertion point: before "## 重要決策記錄" section
    const insertMarker = '## 重要決策記錄';
    const insertPoint = agentsContent.indexOf(insertMarker);

    if (insertPoint > 0) {
      agentsContent = agentsContent.substring(0, insertPoint) + ruleBlock + '\n' + agentsContent.substring(insertPoint);
