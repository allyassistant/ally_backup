#!/usr/bin/env node

const _quiet = process.argv.includes('--quiet');
const log = (...args) => { if (!_quiet) console.log(...args); };

/**
 * Weekly Correction Loop Script - Level 3 Enhanced
 * 每周日自動運行：
 * 1. 讀取 errors.json 分析 pattern
 * 2. 重複錯誤生成規則草案
 * 3. 問用戶確認後加入 AGENTS.md P0
 *
 * Run: node scripts/weekly_correction_loop.js
 * Trigger: Every Sunday 6:00 PM (cron)
 */

const fs = require('fs');
const path = require('path');
const os = require('os');

let ERRORS_JSON, WS, MEMORY_DIR;
try {
  ({ ERRORS_JSON, WS, MEMORY_DIR } = require('./lib/config'));
} catch (e) {
  console.error('❌ Failed to load config:', e.message);
  process.exit(1);
}

// Validate environment and paths
if (!WS || typeof WS !== 'string') {
  console.error('❌ WORKSPACE path not properly configured');
  process.exit(1);
}
if (!ERRORS_JSON || typeof ERRORS_JSON !== 'string') {
  console.error('❌ ERRORS_JSON path not properly configured');
  process.exit(1);
}
const { getHKTDate, getHKTDateTime } = require('./lib/time');
const AGENTS_FILE = (() => { try { return path.join(WS, 'AGENTS.md'); } catch (e) { console.error(`⚠️ Failed to create AGENTS_FILE: ${e.message}`); return ''; } })();
const STATE_FILE = (() => { try { return path.join(MEMORY_DIR, 'correction-loop-state.json'); } catch (e) { console.error(`⚠️ Failed to create STATE_FILE: ${e.message}`); return '/tmp/correction-loop-state.json'; } })();

// CONFIG: Magic numbers centralized
const CONFIG = {
  // Error analysis
  RECENT_ERRORS_DAYS: 7,          // Look back 7 days for recent errors
  MIN_OCCURRENCES_AUTO_ADD: 3,   // 3+ occurrences to auto-add rule
  MAX_PROCESSED_ERRORS: 100,      // Keep last 100 error IDs in state
  FALLBACK_DAYS: 8,               // Force run if no run in 8+ days

  // Report formatting
  TRUNCATE_LIMIT: 1024,           // Truncate field values at 1024 chars
  EMBED_LIMIT: 5900,              // Discord embed character limit
  RULE_PREVIEW_LENGTH: 60,        // Rule preview length in notifications

  // Backup retention
  MAX_BACKUPS: 7,                // Keep last 7 AGENTS.md backups

  // Discord
  DISCORD_CHANNEL_ID: process.env.DISCORD_SYSTEM_CHANNEL_ID || '1473376125584670872',
};

// HKT Date helper
log('=== Weekly Correction Loop (Level 3) ===\n');
log(`📅 Run time: ${getHKTDateTime()}\n`);

// Load state (simplified: single-level try-catch + early return)
let state = { lastRun: null, lastRunDate: null, processedErrors: [], proposedRules: [], confirmedRules: [] };
try {
  if (!fs.existsSync(STATE_FILE)) {
    log('⚠️ State file not found, starting fresh');
  } else {
    let fileContent;
    try {
      fileContent = fs.readFileSync(STATE_FILE, 'utf8');
    } catch (e) {
      console.error('⚠️ File read failed: ' + e.message);
      fileContent = '';
    }
    if (!fileContent.trim()) {
      log('⚠️ State file is empty, starting fresh');
    } else {
      try {
        state = JSON.parse(fileContent);
      } catch (e) {
        console.error('⚠️ JSON parse failed: ' + e.message);
        state = { lastRun: null, lastRunDate: null, processedErrors: [], proposedRules: [], confirmedRules: [] };
      }
    }
  }
} catch (e) {
  log('⚠️ Could not load/parse state, starting fresh: ' + e.message);
  state = { lastRun: null, lastRunDate: null, processedErrors: [], proposedRules: [], confirmedRules: [] };
}

// LOCK CHECK: Prevent multiple runs in same day
const todayDate = getHKTDate();

if (state.lastRunDate === todayDate) {
  log(`⏭️ Already ran today (${state.lastRunDate}). Skipping to prevent duplicate.`);
  log(`   Last run: ${state.lastRun}`);
  process.exit(0);
}

// FALLBACK CHECK: Force run if last run was more than 8 days ago
if (state.lastRunDate) {
  try {
    const lastRunTime = new Date(state.lastRunDate);
    const now = new Date(getHKTDate());
    const daysSinceLastRun = Math.floor((now - lastRunTime) / (1000 * 60 * 60 * 24));
    if (daysSinceLastRun >= CONFIG.FALLBACK_DAYS) {
      log(`🔄 Fallback triggered: Last ran ${daysSinceLastRun} days ago (${state.lastRunDate}). Forcing run.`);
    } else {
      log(`⏭️ Last ran ${daysSinceLastRun} days ago. Skipping until Sunday.`);
      process.exit(0);
    }
  } catch (e) {
    // If date parsing fails, run anyway
    log(`⚠️ Could not parse lastRunDate, proceeding with run: ${e.message}`);
  }
}

// Read errors.json (simplified: single-level try-catch + early return)
let errorsData = { errors: [] };
try {
  if (!fs.existsSync(ERRORS_JSON)) {
    log('⚠️ errors.json not found, starting fresh');
  } else {
    let fileContent;
    try {
      fileContent = fs.readFileSync(ERRORS_JSON, 'utf8');
    } catch (e) {
      console.error('⚠️ File read failed: ' + e.message);
      fileContent = '';
    }
    if (!fileContent.trim()) {
      log('⚠️ errors.json is empty, starting fresh');
    } else {
      try {
        errorsData = JSON.parse(fileContent);
      } catch (e) {
        console.error('⚠️ JSON parse failed: ' + e.message);
        errorsData = { errors: [] };
      }
    }
  }
  log(`✅ Read errors.json: ${errorsData.errors?.length || 0} total errors`);
} catch (e) {
  log('❌ Error reading/parsing errors.json:', e.message);
  process.exit(1);
}

// ============================================
// 方案 A：整合 Pure AI Audit Findings (放到後面用)
// ============================================
// Audit file path defined here but loaded later to match script flow
const AUDIT_FILE = (() => {
  try { return path.join(WS, '.state/pure_ai_audit_results.json'); }
  catch (e) { return ''; }
})();

// Filter recent errors (within 7 days)
const today = new Date();
const oneWeekAgo = new Date(today);
oneWeekAgo.setDate(oneWeekAgo.getDate() - CONFIG.RECENT_ERRORS_DAYS);

const recentErrors = (errorsData.errors || []).filter(error => {
  const errorDate = new Date(error.date || error.timestamp);
  return errorDate >= oneWeekAgo;
});

log(`📊 Found ${recentErrors.length} errors from this week\n`);

// ============================================
// 方案 A：整合 Pure AI Audit Findings
// ============================================
let auditFindings = { findings: [], issues: [], timestamp: null, total_files_audited: 0 };
try {
  if (!AUDIT_FILE || !fs.existsSync(AUDIT_FILE)) {
    log('⚠️ Pure AI Audit results file not found');
  } else {
    let auditContent;
    try {
      auditContent = fs.readFileSync(AUDIT_FILE, 'utf8');
    } catch (e) {
      console.error('⚠️ File read failed: ' + e.message);
      auditContent = '';
    }
    if (!auditContent.trim()) {
      log('⚠️ Pure AI Audit results file is empty');
    } else {
      try {
        const parsed = JSON.parse(auditContent);
        // Support both 'findings' and 'issues' field names
        auditFindings = {
          findings: parsed.findings || parsed.issues || [],
          issues: parsed.issues || parsed.findings || [],
          timestamp: parsed.timestamp || null,
          total_files_audited: parsed.total_files_audited || 0
        };
      } catch (e) {
        console.error('⚠️ JSON parse failed: ' + e.message);
        auditFindings = { issues: [], timestamp: null, total_files_audited: 0 };
      }
      log(`✅ Read Pure AI Audit: ${auditFindings.findings?.length || 0} issues found`);
    }
  }
} catch (e) {
  log('⚠️ Error reading/parsing Pure AI Audit results:', e.message);
}

