function sendDiscordNotification(message) {
  const token = getDiscordToken();
  if (!token) {
    log('❌ No Discord token, skipping notification');
    return;
  }

  const options = {
    hostname: 'discord.com',
    path: `/api/v10/channels/${CONFIG.DISCORD_CHANNEL_ID}/messages`,
    method: 'POST',
    headers: {
      'Authorization': 'Bot ' + token,
      'Content-Type': 'application/json'
    }
  };

  return new Promise((resolve, reject) => {
    const req = require('https').request(options, (res) => {
      let data = '';
      res.on('data', c => data += c);
      res.on('end', () => {
        if (res.statusCode === 200 || res.statusCode === 204) {
          log('✅ Discord notification sent');
          resolve({ status: res.statusCode });
        } else {
          log(`❌ Discord API error: ${res.statusCode}`);
          reject(new Error(`HTTP ${res.statusCode}`));
        }
      });
    });
    req.on('error', (err) => {
      log('❌ Failed to send Discord:', err.message);
      reject(err);
    });
    req.write(JSON.stringify({ content: message }));
    req.end();
  });
}

async function sendAutoAppliedNotification(rules) {
  if (rules.length === 0) return;

  const ruleList = rules.map((r, i) => `${i + 1}. **${r.title}**\n   ${r.rule.substring(0, CONFIG.RULE_PREVIEW_LENGTH)}...`).join('\n\n');
  const message = `🤖 每周校正循環 - 自動應用規則\n\n根據 ${rules.reduce((sum, r) => sum + r.occurrences, 0)} 次重複錯誤（出現 3+ 次、高/嚴重級別），我已自動將 ${rules.length} 條新規則加入 AGENTS.md：\n\n${ruleList}\n\n✅ 規則已生效，下次啟動時會自動載入。\n📝 如需修改或刪除，請直接編輯 AGENTS.md。\n⚡ 自動應用條件：出現 3+ 次 + 高/嚴重級別`;

  await sendDiscordNotification(message).catch(e => log('⚠️ Discord failed:', e.message));
}

