// Helper functions
function extractErrorPattern(error) {
  // Extract pattern from error
  const title = error.title || error.problem || '';
  const category = error.category || 'general';

  // Normalize similar errors
  let pattern = title.toLowerCase()
    .replace(/\d{4}-\d{2}-\d{2}/g, 'DATE')
    .replace(/\d+/g, 'NUM')
    .replace(/\s+/g, ' ')
    .trim();

  // Extract key keywords
  const keywords = ['trash', 'rm', 'time', 'timezone', 'utc', 'hkt', 'backup', 'sync'];
  const matched = keywords.filter(kw => pattern.includes(kw));

  if (matched.length > 0) {
    return `${category}:${matched.join('-')}`;
  }

  return `${category}:${pattern.substring(0, 50)}`;
}

function generateRuleFromPattern(key, data) {
  try {
    const errors = data.errors || [];
    const titles = errors.map(e => { try { return e.title || e.problem || ''; } catch (err) { return ''; } }).join(' ');

    // Rule generation logic based on error patterns
    let rule = null;
    let title = '';

    if (key.includes('trash') || titles.toLowerCase().includes('trash')) {
      title = '使用 trash 命令';
      rule = '必須使用 trash 命令移動文件到回收站，禁止使用 rm 或 unlinkSync 直接刪除。';
    } else if (key.includes('time') || key.includes('utc') || key.includes('hkt') || titles.toLowerCase().includes('timezone')) {
      title = '時間時區統一';
      rule = '所有時間操作必須使用 HKT (Asia/Hong_Kong) 時區，使用 toLocaleString("zh-HK", { timeZone: "Asia/Hong_Kong" }) 而非 toISOString()。';
    } else if (key.includes('backup') || titles.toLowerCase().includes('backup')) {
      title = '備份驗證';
      rule = '備份操作完成後必須立即驗證，確保內容完整且可讀取。';
    } else if (key.includes('sync') || titles.toLowerCase().includes('sync')) {
      title = '同步機制';
      rule = '涉及多個系統同步時，必須有重試機制同最終一致性檢查。';
    }

    if (rule) {
      return {
        id: `rule-${Date.now()}-${Math.random().toString(36).slice(2, 11)}`,
        title,
        pattern: key,
        occurrences: data.count,
        rule,
        errors: errors.map(e => { try { return { id: e.id, date: e.date, title: e.title }; } catch (err) { return null; } }).filter(Boolean),
        proposedDate: getHKTDate(),
        status: 'pending_confirmation'
      };
    }
  } catch (err) {
    console.error('Error in rule generation:', err.message);
  }

  return null;
}

function isRuleAlreadyProposed(rule, proposedRules) {
  if (!proposedRules || proposedRules.length === 0) return false;
  return proposedRules.some(pr => pr.pattern === rule.pattern && pr.status !== 'rejected');
}

function isRuleAlreadyApplied(rule, confirmedRules) {
  if (!confirmedRules || confirmedRules.length === 0) return false;
  return confirmedRules.some(cr => cr.pattern === rule.pattern);
}

function applyAutoRules(rules, agentsFile, state) {
  if (rules.length === 0) return [];

  let agentsContent = '';
  try {
    agentsContent = fs.readFileSync(agentsFile, 'utf8');
  } catch (e) {
    log('❌ Error reading AGENTS.md:', e.message);
    return [];
  }

  const appliedRules = [];

  rules.forEach(rule => {
    try {
      // Check if already in AGENTS.md
      if (!rule.rule || agentsContent.includes(rule.rule.substring(0, 30))) {
        log(`⏭️ Rule already in AGENTS.md: ${rule.title}`);
        rule.applied = true;
        return;
      }

      // Add to AGENTS.md with auto-generated marker
      const ruleEntry = `\n### 🎯 P0 - ${rule.title} (Auto-generated)\n*📅 Created: ${rule.proposedDate} | 🔄 Updated: ${getHKTDate()} | ⏰ TTL: Never | 🤖 Auto*\n\n${rule.rule}\n\n> 🔄 **Auto-Applied Rule**\n> - 來源：基於 ${rule.occurrences} 次同類型錯誤自動生成\n> - 錯誤 ID: ${(rule.errors || []).map(e => e.id).join(', ')}\n> - 生成時間: ${getHKTDateTime()}\n> - 如需修改/刪除，請手動編輯 AGENTS.md\n`;

      // Find insertion point (before "## 重要決策記錄" section)
      const insertPoint = agentsContent.indexOf('## 重要決策記錄');
      if (insertPoint > 0) {
        agentsContent = agentsContent.substring(0, insertPoint) + ruleEntry + '\n' + agentsContent.substring(insertPoint);
        appliedRules.push(rule);
        rule.applied = true;
        log(`✅ Auto-applied rule: ${rule.title}`);
      }
    } catch (e) {
      log(`⚠️ Failed to apply rule ${rule.title}: ${e.message}`);
    }
  });

  if (appliedRules.length > 0) {
    // ── Backup AGENTS.md before writing (保留最近 7 個備份) ──
    const todayStr = new Date().toISOString().slice(0, 10).replace(/-/g, '');
    const backupPattern = /^AGENTS\.md\.bak\.\d{8}$/;

    // 1. Ensure backup directory exists
    const agentsDir = path.dirname(agentsFile);
    try {
      if (!fs.existsSync(agentsDir)) {
        try {
          fs.mkdirSync(agentsDir, { recursive: true });
        } catch (e) {
          if (e.code !== 'EEXIST') {
            console.error('⚠️ mkdir failed: ' + e.message);
          }
        }
      }
    } catch (e) {
      log(`⚠️ Could not check backup dir (continuing): ${e.message}`);
    }

    // 2. Create backup: cp AGENTS.md AGENTS.md.bak.YYYYMMDD
    const backupFile = path.join(agentsDir, `AGENTS.md.bak.${todayStr}`);
    try {
      fs.copyFileSync(agentsFile, backupFile);
      log(`📦 Backup created: AGENTS.md.bak.${todayStr}`);
    } catch (e) {
      console.error('⚠️ copyFile failed: ' + e.message);
    }

    // 2.5 Ensure backup directory exists (in case agentsDir was created during backup)
    try {
      fs.mkdirSync(agentsDir, { recursive: true });
    } catch (e) {
      if (e.code !== 'EEXIST') {
        console.error('⚠️ mkdir failed: ' + e.message);
      }
    }

    // 3. Keep only the 7 most recent backups (delete older ones)
    let backups = [];
    try {
      backups = fs.readdirSync(agentsDir)
        .filter(f => backupPattern.test(f))
        .sort()
        .reverse(); // newest first
    } catch (e) {
      console.error('⚠️ readdir failed: ' + e.message);
      backups = [];
    }

    if (backups.length > CONFIG.MAX_BACKUPS) {
      const toDelete = backups.slice(7); // 8th, 9th, ... oldest
      for (const oldBackup of toDelete) {
        try {
          fs.unlinkSync(path.join(agentsDir, oldBackup));
          log(`🗑️ Cleaned old backup: ${oldBackup}`);
        } catch (e) {
          console.error('⚠️ unlink failed: ' + e.message);
        }
      }
    }

    // Cleanup: ensure backups array is initialized even if readdir failed
    if (!backups) {
      backups = [];
    }

    // ── Atomic write for AGENTS.md ──
    const tmpFile = agentsFile + '.tmp';
    try {
      fs.writeFileSync(tmpFile, agentsContent);
      fs.renameSync(tmpFile, agentsFile);
      log(`✅ Updated AGENTS.md with ${appliedRules.length} auto-applied rules`);
    } catch (e) {
      console.error('⚠️ Atomic write failed: ' + e.message);
      // Cleanup temp file if it exists
      try {
        fs.unlinkSync(tmpFile);
      } catch (cleanupErr) {
        // Ignore cleanup errors
      }
    }
  }

  return appliedRules;
}

