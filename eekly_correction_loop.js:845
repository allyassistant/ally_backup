function truncateFieldValue(value, limit = CONFIG.TRUNCATE_LIMIT) {
  if (!value || typeof value !== 'string') return '\u200b';
  if (value.length <= limit) return value;
  return value.substring(0, limit - 3) + '...';
}

function enforceEmbedLimit(embed, limit = CONFIG.EMBED_LIMIT) {
  const countChars = () => {
    let total = (embed.title || '').length + (embed.description || '').length;
    if (embed.footer && embed.footer.text) total += embed.footer.text.length;
    if (embed.author && embed.author.name) total += embed.author.name.length;
    for (const f of (embed.fields || [])) {
      total += (f.name || '').length + (f.value || '').length;
    }
    return total;
  };
  let total = countChars();
  if (total <= limit) return embed;
  const fields = embed.fields || [];
  while (total > limit && fields.length > 0) {
    let longestIdx = 0;
    let longestLen = 0;
    for (let i = 0; i < fields.length; i++) {
      const vLen = (fields[i].value || '').length;
      if (vLen > longestLen) { longestLen = vLen; longestIdx = i; }
    }
    if (longestLen <= 10) break;
    const excess = total - limit;
    const newLen = Math.max(10, longestLen - excess - 3);
    fields[longestIdx].value = fields[longestIdx].value.substring(0, newLen) + '...';
    total = countChars();
  }
  return embed;
}

async function sendWeeklyReport(recentErrors, errorPatterns, autoAppliedRules) {
  const totalErrors = recentErrors.length;
  const patternCount = Object.keys(errorPatterns).length;
  const newRulesCount = autoAppliedRules.length;
  const auditRulesCount = auditPreventionRules.length;
  const todayStr = getHKTDate();

  // === Load state for trend comparison ===
  let lastErrorStats = { total: 0, patterns: 0, errorTypes: {} };
  let lastAuditReportDate = null;
  let lastAuditHash = null;
  try {
    if (fs.existsSync(STATE_FILE)) {
      let stateDataRaw;
      try {
        stateDataRaw = fs.readFileSync(STATE_FILE, 'utf8');
      } catch (e) {
        console.error('⚠️ File read failed: ' + e.message);
        stateDataRaw = '{}';
      }
      try {
        const stateData = JSON.parse(stateDataRaw);
        lastErrorStats = stateData.lastErrorStats || lastErrorStats;
        lastAuditReportDate = stateData.lastAuditReportDate || null;
        lastAuditHash = stateData.lastAuditHash || null;
      } catch (e) {
        console.error('⚠️ JSON parse failed: ' + e.message);
      }
    }
  } catch (e) {
    log('⚠️ Could not load state for trend:', e.message);
  }

  // === Calculate audit hash to detect changes ===
  const currentAuditHash = auditFindings.findings ?
    JSON.stringify(auditFindings.findings.map(i => `${i.category}:${i.severity}`).sort()) : '';
  const auditChanged = lastAuditHash !== currentAuditHash;

  // === Error trend analysis ===
  const trendChange = lastErrorStats.total > 0 ?
    Math.round((totalErrors - lastErrorStats.total) / lastErrorStats.total * 100) : 0;
  const trendArrow = trendChange > 0 ? '↑' : (trendChange < 0 ? '↓' : '→');

  // === Get top 3 error patterns with trend ===
  const topPatterns = totalErrors > 0 ?
    Object.entries(errorPatterns).sort((a, b) => b[1].count - a[1].count).slice(0, 3) : [];

  // === Trend analysis by error type ===
  const trendAnalysis = [];
  if (lastErrorStats.errorTypes && Object.keys(lastErrorStats.errorTypes).length > 0) {
    const currentTypes = {};
    for (const [key, data] of Object.entries(errorPatterns)) {
      currentTypes[key] = data.count;
    }
    for (const [type, lastCount] of Object.entries(lastErrorStats.errorTypes)) {
      const currentCount = currentTypes[type] || 0;
      if (currentCount > lastCount) {
        trendAnalysis.push({ type, change: currentCount - lastCount, direction: 'up' });
      } else if (currentCount < lastCount && currentCount > 0) {
        trendAnalysis.push({ type, change: lastCount - currentCount, direction: 'down' });
      }
    }
    // New types this week
    for (const type of Object.keys(currentTypes)) {
      if (!(type in (lastErrorStats.errorTypes || {}))) {
        trendAnalysis.push({ type, change: currentTypes[type], direction: 'new' });
      }
    }
  }

  // === P0/P1 counts (pure_ai_audit uses lowercase: 'critical'/'high') ===
  let p0Count = 0, p1Count = 0;
  if (auditFindings.findings && auditFindings.findings.length > 0) {
    p0Count = auditFindings.findings.filter(i => i.severity === 'critical').length;
    p1Count = auditFindings.findings.filter(i => i.severity === 'high').length;
  }

  // === Build report (Chinese version) ===
  const reportLines = [
    `🔄 **每週校正循環報告** | ${todayStr}`,
    ``,
    `📊 本週錯誤概覽`,
    `• 本週: ${totalErrors} 個錯誤，${patternCount} 種模式 (${trendArrow}${Math.abs(trendChange)}% vs 上週 ${lastErrorStats.total} 個)`,
    `• AI 分類: ${Object.keys(categorizedErrors).length} 個類別`,
    ``,
    `🔴 本週主要問題 (Top 3)`,
    ...(topPatterns.length > 0 ?
      topPatterns.map(([key, data], i) => {
        const lastCount = lastErrorStats.errorTypes?.[key] || 0;
        const diff = data.count - lastCount;
        const diffArrow = diff > 0 ? '↑' : (diff < 0 ? '↓' : '→');
        return `${i + 1}. ${key} (${data.count}x) ${diffArrow}`;
      }) : ['• 本週冇錯誤']),
    ``,
    `📈 趨勢分析`,
    ...(trendAnalysis.length > 0 ?
      trendAnalysis.slice(0, 3).map(t => {
        if (t.direction === 'new') return `🆕 ${t.type}: 新增 ${t.change}x`;
        if (t.direction === 'up') return `↑ ${t.type}: +${t.change}x`;
        return `↓ ${t.type}: -${t.change}x`;
      }) : ['• 無上週數據對比']),
    ``,
    `🔍 Pure AI Audit`,
    ...(auditChanged ?
      [`• 🆕 審計有變化！發現 ${p0Count} 個 P0, ${p1Count} 個 P1`] :
      [`• 無變化 (上次報告: ${lastAuditReportDate || '從未'})`]),
    ``,
    `🛠️ 自動修復`,
    newRulesCount > 0 ? `• 本週新增 ${newRulesCount} 條規則` : `• 本週無新規則`,
    auditRulesCount > 0 ? `• Prevention Rules: ${auditRulesCount} 條已生效` : `• Prevention Rules: 無`,
    ``,
    `💡 下週行動建議`,
    ...(p0Count > 0 ? [`⚠️ 處理 ${p0Count} 個 P0 代碼問題`] :
        (trendAnalysis.filter(t => t.direction === 'up').length > 0 ? ['📊 監控上升趨勢的錯誤類型'] : ['🎉 系統健康，保持現狀'])),
    ``,
    `🤖 由 Ally 生成 | 每週校正循環 v4`
  ];

  // === Send Discord notification FIRST, then update state ===
  await sendDiscordNotification(reportLines.join('\n')).catch(e => log('⚠️ Discord weekly report failed:', e.message));

  // === Update state with current stats ===
  const newState = {
    lastRun: getHKTDateTime(),
    lastRunDate: todayStr,
    processedErrors: recentErrors.slice(0, CONFIG.MAX_PROCESSED_ERRORS).map(e => e.id || e.title || 'unknown'),
    proposedRules: [],
    confirmedRules: [],
    auditPreventionRules: auditPreventionRules || [],
    lastAuditHash: currentAuditHash,
    lastAuditReportDate: auditChanged ? todayStr : lastAuditReportDate,
    lastErrorStats: {
      total: totalErrors,
      patterns: patternCount,
      errorTypes: Object.fromEntries(
        Object.entries(errorPatterns).map(([k, v]) => [k, v.count])
      )
    }
  };

  const tmpFile = STATE_FILE + '.tmp';
  try {
    fs.writeFileSync(tmpFile, JSON.stringify(newState, null, 2));
    fs.renameSync(tmpFile, STATE_FILE);
  } catch (e) {
    console.error('⚠️ Atomic write failed: ' + e.message);
    // Cleanup temp file if it exists
    try {
      fs.unlinkSync(tmpFile);
    } catch (cleanupErr) {
      // Ignore cleanup errors
    }
  }
}
