{
  "version": "1.1",
  "lastUpdated": "2026-03-25T03:40:00.000Z",
  "patterns": {
    "RATE_LIMIT": {
      "pattern": "rate limit|429|too many requests|rate_limit",
      "category": "api",
      "severity": "medium",
      "autoFix": {
        "enabled": true,
        "action": "wait_and_retry",
        "description": "等待一段時間後重試 (Rate Limit 需要時間冷卻)"
      }
    },
    "AUTH_ERROR_401": {
      "pattern": "401|unauthorized|authentication failed|invalid api key|auth.*error",
      "category": "api",
      "severity": "high",
      "autoFix": {
        "enabled": false,
        "action": "notify_user",
        "description": "需要人手更新 API Key"
      }
    },
    "MINIMAX_ERROR": {
      "pattern": "minimax.*error|api error|api.*aborted",
      "category": "api",
      "severity": "medium",
      "autoFix": {
        "enabled": false,
        "action": "switch_model",
        "description": "切換到其他 model (如 Kimi)"
      }
    },
    "DISCORD_ERROR": {
      "pattern": "discord.*error|channel.*error|discord api|discord.com/api",
      "category": "delivery",
      "severity": "medium",
      "autoFix": {
        "enabled": false,
        "action": "check_discord_token",
        "description": "檢查 Discord token 是否過期"
      }
    },
    "KIMI_ERROR": {
      "pattern": "kimi.*error|kimi.*rate.*limit|kimi.*timeout",
      "category": "api",
      "severity": "medium",
      "autoFix": {
        "enabled": false,
        "action": "wait_and_retry",
        "description": "等待後重試"
      }
    },
    "REQUEST_ABORTED": {
      "pattern": "request aborted|aborted|ECONNRESET",
      "category": "network",
      "severity": "low",
      "autoFix": {
        "enabled": true,
        "action": "retry_request",
        "description": "重新發送請求"
      }
    },
    "L1_TIMEOUT": {
      "pattern": "L1.*timeout|cron.*job execution timed out",
      "category": "performance",
      "severity": "medium",
      "autoFix": {
        "enabled": true,
        "action": "increase_timeout",
        "description": "增加 L1 Generator timeout",
        "steps": [
          "檢查昨日 memory 檔案大小",
          "用 adaptive_timeout.js 計算新 timeout",
          "更新 cron job"
        ]
      },
      "fallbackAction": "use_extraction"
    },
    "L0_TIMEOUT": {
      "pattern": "L0.*timeout|generate_abstract.*timeout",
      "category": "performance",
      "severity": "low",
      "autoFix": {
        "enabled": true,
        "action": "increase_timeout",
        "description": "增加 L0 Generator timeout"
      },
      "fallbackAction": "use_extraction"
    },
    "MODEL_NOT_ALLOWED": {
      "pattern": "model not allowed|invalid model",
      "category": "configuration",
      "severity": "high",
      "autoFix": {
        "enabled": true,
        "action": "fix_model_name",
        "description": "修正 model 名稱 (例如 minimax-portal/qwen3 → ollama/qwen3)"
      }
    },
    "DISCORD_DELIVERY_FAILED": {
      "pattern": "discord.*delivery failed|announce delivery failed",
      "category": "delivery",
      "severity": "medium",
      "autoFix": {
        "enabled": false,
        "action": "check_discord_connection",
        "description": "檢查 Discord connection"
      }
    },
    "FILE_NOT_FOUND": {
      "pattern": "file not found|no such file|ENOENT",
      "category": "filesystem",
      "severity": "high",
      "autoFix": {
        "enabled": false,
        "action": "create_missing_file",
        "description": "創建缺失檔案 (需要人手確認內容)"
      }
    },
    "MEMORY_CLEANUP_NEEDED": {
      "pattern": "memory.*full|disk.*full|cleanup needed",
      "category": "maintenance",
      "severity": "high",
      "autoFix": {
        "enabled": true,
        "action": "run_cleanup",
        "description": "執行 cleanup scripts"
      }
    },
    "OLLAMA_401": {
      "pattern": "401 Authentication|Auth Error|Invalid API key|401 Unauthorized",
      "category": "auth",
      "severity": "high",
      "autoFix": {
        "enabled": true,
        "action": "handle_ollama_401",
        "description": "Ollama 401 → 標記為已知問題，通知 human，自動 skip"
      }
    },
    "MEMORY_OOM": {
      "pattern": "Out of memory|Memory Error",
      "category": "memory",
      "severity": "high",
      "autoFix": {
        "enabled": true,
        "action": "handle_memory_oom",
        "description": "OOM → archive session，reset memory"
      }
    }
  }
}