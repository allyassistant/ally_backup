/**
 * Diamond Valuation Skill (Rapaport Calculator)
 */

const SKILL = {
  name: "diamond_valuation",
  keywords: ["diamond", "鑽石", "rapaport", "估價", "價格", "幾多錢", "咩價"]
};

function estimateValue(input) {
  return {
    skill: "diamond_valuation",
    input: input,
    message: "💎 Diamond Valuation Skill 已載入！\n\n請提供：\n• Carat (卡數)\n• Color (顏色)\n• Clarity (淨度)\n• Shape (形狀，可選)\n\n例如：「2.5卡 H VS1 Round」",
    example: "呢粒2.5卡 H VS1 Round 幾多錢？"
  };
}

module.exports = { skill: SKILL, estimateValue };
