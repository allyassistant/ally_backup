/**
 * Skill: Excel AI Formula Generator
 * 
 * 來源: Perplexity Search - Excel AI formulas automation 2026
 * 創建日期: 2026-02-15
 * 
 * 描述: 根據自然語言描述生成 Excel 公式
 * 
 * Sources:
 * - Microsoft Copilot: "Show quarterly growth rates, ignoring blank cells"
 * - Formula Bot / Ajelix: Bidirectional formula generation
 * - AI-powered data cleanup: Remove duplicates, correct dates
 * - Natural language queries: "What were top 5 products by revenue?"
 * - Predictive forecasting: ML-based predictions
 * - Smart visualization: AI chart recommendations
 */

const SKILL_INFO = {
  name: "excel_formula_generator",
  version: "1.0.0",
  created: "2026-02-15",
  source: "Perplexity Search",
  description: "根據自然語言生成 Excel 公式、數據清理、預測分析",
  
  capabilities: [
    "自然語言生成公式",
    "公式解釋",
    "數據自動清理",
    "自然語言查詢",
    "預測分析",
    "智能图表建議"
  ],
  
  examples: [
    {
      input: "Show quarterly growth rates, ignoring blank cells",
      output: "=IFERROR((B2-A2)/A2, 0)",
      explanation: "計算季度增長率，跳過空白儲存格"
    },
    {
      input: "Top 5 products by revenue in Q3",
      output: "PivotTable or =LARGE(range, k)",
      explanation: "找出Q3收入最高的5個產品"
    },
    {
      input: "Remove duplicates",
      output: "Data > Remove Duplicates or =UNIQUE()",
      explanation: "去除重複數據"
    }
  ]
};

/**
 * 生成 Excel 公式
 * @param {string} description - 自然語言描述
 * @param {object} context - Excel 數據範圍
 * @returns {object} - 公式和解釋
 */
function generateFormula(description, context = {}) {
  const descriptionLower = description.toLowerCase();
  
  // 匹配常見需求
  const patterns = {
    growth: {
      regex: /growth|增長|成長|比率/i,
      formula: (range) => `=IFERROR((${range}[end] - ${range}[start]) / ${range}[start], 0)`,
      explanation: "計算增長率，跳過錯誤值"
    },
    sum: {
      regex: /sum|總計|加總/i,
      formula: (range) => `=SUM(${range})`,
      explanation: "加總範圍內所有數值"
    },
    average: {
      regex: /average|平均|均值/i,
      formula: (range) => `=AVERAGE(${range})`,
      explanation: "計算平均值"
    },
    top: {
      regex: /top|first|largest|最高|最大/i,
      formula: (range, k = 1) => `=LARGE(${range}, ${k})`,
      explanation: "找出第K大的數值"
    },
    unique: {
      regex: /unique|distinct|不重複|去重/i,
      formula: (range) => `=UNIQUE(${range})`,
      explanation: "提取不重複的值"
    },
    if: {
      regex: /if|如果|假如|則/i,
      formula: (condition) => `=IF(${condition}, "是", "否")`,
      explanation: "條件判斷"
    },
    vlookup: {
      regex: /lookup|查找|搜尋|搵/i,
      formula: (lookup, range, col) => `=VLOOKUP("${lookup}", ${range}, ${col}, FALSE)`,
      explanation: "在範圍內查找值"
    },
    indexMatch: {
      regex: /index|match|索引|配對/i,
      formula: (lookup, range1, range2) => `=INDEX(${range2}, MATCH("${lookup}", ${range1}, 0))`,
      explanation: "更靈活的查找組合"
    },
    removeDuplicates: {
      regex: /duplicate|重複|去除/i,
      formula: "Data > Remove Duplicates 或 =UNIQUE()",
      explanation: "去除重複數據"
    },
    forecast: {
      regex: /forecast|預測|預計/i,
      formula: "=FORECAST.LINEAR() 或 AI Copilot",
      explanation: "基於歷史數據的預測"
    }
  };
  
  // 匹配模式
  for (const [key, pattern] of Object.entries(patterns)) {
    if (pattern.regex.test(descriptionLower)) {
      return {
        skill: SKILL_INFO.name,
        input: description,
        formula: pattern.formula,
        explanation: pattern.explanation,
        tip: `提示: 在 Excel 中，可以直接用 Copilot: "Home > Copilot > ${description}"`
      };
    }
  }
  
  // 預設：返回 Copilot 建議
  return {
    skill: SKILL_INFO.name,
    input: description,
    formula: null,
    suggestion: "建議使用 Microsoft Copilot: Home > Copilot > Describe your needs",
    explanation: "複雜需求建議用 AI Copilot 直接處理"
  };
}

/**
 * 解釋現有公式
 * @param {string} formula - Excel 公式
 * @returns {string} - 通俗解釋
 */
function explainFormula(formula) {
  // 簡單的公式解釋
  const explanations = {
    'SUM': '將所有數值加總',
    'AVERAGE': '計算所有數值的平均',
    'IF': '如果條件成立，返回一個值，否則返回另一個值',
    'VLOOKUP': '在表格中垂直查找指定值',
    'INDEX': '返回表格中指定位置的值',
    'MATCH': '查找值在範圍中的位置',
    'UNIQUE': '提取不重複的唯一值',
    'LARGE': '返回第K大的值',
    'IFERROR': '如果公式出錯，返回指定值'
  };
  
  // 提取公式函數
  const match = formula.match(/^=([A-Z]+)/i);
  if (match && explanations[match[1]]) {
    return explanations[match[1]];
  }
  
  return "需要更多上下文來解釋此公式";
}

/**
 * 數據清理建議
 * @param {object} dataIssues - 數據問題描述
 * @returns {array} - 建議行動
 */
function suggestDataCleanup(dataIssues) {
  const suggestions = [];
  
  if (dataIssues.hasDuplicates) {
    suggestions.push({
      action: "去除重複",
      method: "Data > Remove Duplicates 或 =UNIQUE()",
      formula: "=UNIQUE(A:A)"
    });
  }
  
  if (dataIssues.inconsistentDates) {
    suggestions.push({
      action: "修正日期格式",
      method: "Select cells > Home > Copilot > Fix dates",
      formula: "=DATEVALUE() 或 =TEXT()"
    });
  }
  
  if (dataIssues.missingValues) {
    suggestions.push({
      action: "處理空白值",
      method: "=IFERROR(formula, default_value) 或 =IF(ISBLANK(), ...)",
      tip: "用 IFERROR 防止錯誤值影響計算"
    });
  }
  
  return {
    skill: SKILL_INFO.name,
    issues: dataIssues,
    suggestions: suggestions
  };
}

module.exports = {
  skill: SKILL_INFO,
  generateFormula,
  explainFormula,
  suggestDataCleanup
};
