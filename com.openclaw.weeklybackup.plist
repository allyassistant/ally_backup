<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.weeklybackup</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/ally/.openclaw/workspace/scripts/openclaw_guard.sh</string>
        <string>auto</string>
    </array>
    
    <key>StartCalendarInterval</key>
    <dict>
